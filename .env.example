# ──────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=messaging

# ──────────────────────────────────────────
# Kafka
# ──────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# Topic
KAFKA_TOPIC_MESSAGE_SEND=message.send

# api-gateway producer
KAFKA_CLIENT_ID=messaging-api-gateway

# worker-email consumer
KAFKA_WORKER_EMAIL_CLIENT_ID=worker-email
KAFKA_WORKER_EMAIL_GROUP_ID=worker-email-group

# worker-sms consumer
KAFKA_WORKER_SMS_CLIENT_ID=worker-sms
KAFKA_WORKER_SMS_GROUP_ID=worker-sms-group

# worker-kakao consumer
KAFKA_WORKER_KAKAO_CLIENT_ID=worker-kakao
KAFKA_WORKER_KAKAO_GROUP_ID=worker-kakao-group

# ──────────────────────────────────────────
# HTTP Server
# ──────────────────────────────────────────
# Each app reads PORT independently — set per-process or use separate .env files per app
PORT=3000
